--------------------------------------------------------------------------------
local function GetTargetPlayer()
    local targetList = {}
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Team ~= LocalPlayer.Team then
            local char = player.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                local part = char:FindFirstChild(_G.TargetPart)
                if hum and hum.Health > 0 and part then
                    local _, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (part.Position - Camera.CFrame.Position).Magnitude
                        table.insert(targetList, {part = part, dist = dist})
                    end
                end
            end
        end
    end
    if #targetList == 0 then return nil end
    table.sort(targetList, function(a, b) return a.dist < b.dist end)
    return targetList[1].part
end

RunService.Heartbeat:Connect(function()
    CurrentTarget = GetTargetPlayer()
    local c = LocalPlayer.Character
    local t = c and c:FindFirstChildWhichIsA("Tool")
    
    if getgenv().ddddddddd_Config.VoidPosition and c and c:FindFirstChild("HumanoidRootPart") then
        local h = c.HumanoidRootPart
        h.CFrame = h.CFrame + Vector3.new(0, cVoid, 0)
        h.Velocity = Vector3.zero
    end
    
    if t then
        if getgenv().ddddddddd_Config.InfiniteAmmo then
            local ammo = t:FindFirstChild("Ammo")
            if ammo then ammo.Value = 20 end
        end
        if getgenv().ddddddddd_Config.NoRecoil then
            local recoil = t:FindFirstChild("Recoil")
            if recoil then recoil.Value = 0 end
        end
        if getgenv().ddddddddd_Config.FastFire then
            local firerate = t:FindFirstChild("FireRate")
            local cooldown = t:FindFirstChild("Cooldown")
            if firerate then firerate.Value = 0.02 end
            if cooldown then cooldown.Value = 0 end
        end
        if getgenv().ddddddddd_Config.Wallbang and t ~= prevTool then
            prevTool = t
            for _, part in ipairs(t:GetDescendants()) do 
                if part:IsA("BasePart") then part.CanCollide = false end 
            end
        end
    end
end)

