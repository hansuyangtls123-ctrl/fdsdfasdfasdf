task.spawn(function()
    local Utility = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Utility"))
    local oldRaycast = Utility.Raycast
    Utility.Raycast = function(...)
        local args = {...}
        if args[4] == 999 and getgenv().ddddddddd_Config.SilentAim then
            local aimTarget = CurrentTarget or GetTargetPlayer()
            if aimTarget then args[3] = aimTarget.Position end
        end
        return oldRaycast(table.unpack(args))
    end
end)

