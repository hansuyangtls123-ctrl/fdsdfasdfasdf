task.spawn(function()
    local Modules = ReplicatedStorage:WaitForChild("Modules", 20)
    if not Modules then return end
    
    local CosmeticLibrary = require(Modules:WaitForChild("CosmeticLibrary", 10))
    local playerScripts = LocalPlayer:WaitForChild("PlayerScripts")
    local controllers = playerScripts:WaitForChild("Controllers")
    local DataController = require(controllers:WaitForChild("PlayerDataController", 10))

    local oldOwns = CosmeticLibrary.OwnsCosmetic
    CosmeticLibrary.OwnsCosmetic = function(self, inv, name, wp)
        if getgenv().ddddddddd_Config.UnlockAll then return true end
        return oldOwns(self, inv, name, wp)
    end

    local oldGet = DataController.Get
    DataController.Get = function(self, key)
        local data = oldGet(self, key)
        if key == "CosmeticInventory" and getgenv().ddddddddd_Config.UnlockAll then
            local proxy = {}
            return setmetatable(proxy, {__index = function(t, k) return true end})
        end
        return data
    end
end)

